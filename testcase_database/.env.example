# Database connection settings expected by dependent services (e.g., testcase_backend_api)
# Values shown here match the defaults created by startup.sh

POSTGRES_USER=appuser
POSTGRES_PASSWORD=dbuser123
POSTGRES_DB=myapp
POSTGRES_PORT=5000

# Optional convenience URL (some tools use this as a signal that Postgres is configured)
POSTGRES_URL=postgresql://localhost:5000/myapp
